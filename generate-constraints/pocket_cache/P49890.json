{"entryType":"UniProtKB reviewed (Swiss-Prot)","primaryAccession":"P52844","secondaryAccessions":["P49889","P49890","P52845","Q9QWS0"],"uniProtkbId":"ST1E1_RAT","entryAudit":{"firstPublicDate":"1996-10-01","lastAnnotationUpdateDate":"2025-06-18","lastSequenceUpdateDate":"2024-01-24","entryVersion":132,"sequenceVersion":2},"annotationScore":5.0,"organism":{"scientificName":"Rattus norvegicus","commonName":"Rat","taxonId":10116,"lineage":["Eukaryota","Metazoa","Chordata","Craniata","Vertebrata","Euteleostomi","Mammalia","Eutheria","Euarchontoglires","Glires","Rodentia","Myomorpha","Muroidea","Muridae","Murinae","Rattus"]},"proteinExistence":"1: Evidence at protein level","proteinDescription":{"recommendedName":{"fullName":{"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"7857871"}],"value":"Sulfotransferase 1E1"},"shortNames":[{"value":"ST1E1"}],"ecNumbers":[{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"7857871"}],"value":"2.8.2.4"}]},"alternativeNames":[{"fullName":{"value":"Estrogen sulfotransferase, isoform 1"},"shortNames":[{"value":"EST-1"}]},{"fullName":{"value":"Estrogen sulfotransferase, isoform 6"},"shortNames":[{"value":"EST-6"}]},{"fullName":{"value":"Estrone sulfotransferase"}},{"fullName":{"value":"Sulfotransferase, estrogen-preferring"}}]},"genes":[{"geneName":{"evidences":[{"evidenceCode":"ECO:0000312","source":"RGD","id":"3776"}],"value":"Sult1e1"},"synonyms":[{"value":"Ste"},{"value":"Ste1"},{"value":"Ste2"}]}],"comments":[{"texts":[{"evidences":[{"evidenceCode":"ECO:0000250","source":"UniProtKB","id":"P49888"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"7857871"}],"value":"Sulfotransferase that utilizes 3'-phospho-5'-adenylyl sulfate (PAPS) as sulfonate donor to catalyze the sulfate conjugation of estradiol and estrone (PubMed:7857871). Is a key enzyme in estrogen homeostasis, the sulfation of estrogens leads to their inactivation. Also sulfates dehydroepiandrosterone (DHEA), pregnenolone, (24S)-hydroxycholesterol and xenobiotic compounds like ethinylestradiol, equalenin, diethyl stilbesterol and 1-naphthol at significantly lower efficiency. Does not sulfonate cortisol, testosterone and dopamine. May play a role in gut microbiota-host metabolic interaction. O-sulfonates 4-ethylphenol (4-EP), a dietary tyrosine-derived metabolite produced by gut bacteria. The product 4-EPS crosses the blood-brain barrier and may negatively regulate oligodendrocyte maturation and myelination, affecting the functional connectivity of different brain regions associated with the limbic system"}],"commentType":"FUNCTION"},{"commentType":"CATALYTIC ACTIVITY","reaction":{"name":"estrone + 3'-phosphoadenylyl sulfate = estrone 3-sulfate + adenosine 3',5'-bisphosphate + H(+)","reactionCrossReferences":[{"database":"Rhea","id":"RHEA:15973"},{"database":"ChEBI","id":"CHEBI:15378"},{"database":"ChEBI","id":"CHEBI:17263"},{"database":"ChEBI","id":"CHEBI:58339"},{"database":"ChEBI","id":"CHEBI:58343"},{"database":"ChEBI","id":"CHEBI:60050"}],"ecNumber":"2.8.2.4","evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"7857871"}]},"physiologicalReactions":[{"directionType":"left-to-right","reactionCrossReference":{"database":"Rhea","id":"RHEA:15974"},"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"7857871"}]}]},{"commentType":"CATALYTIC ACTIVITY","reaction":{"name":"(24S)-hydroxycholesterol + 3'-phosphoadenylyl sulfate = (24S)-hydroxycholesterol 3-sulfate + adenosine 3',5'-bisphosphate + H(+)","reactionCrossReferences":[{"database":"Rhea","id":"RHEA:52348"},{"database":"ChEBI","id":"CHEBI:15378"},{"database":"ChEBI","id":"CHEBI:34310"},{"database":"ChEBI","id":"CHEBI:58339"},{"database":"ChEBI","id":"CHEBI:58343"},{"database":"ChEBI","id":"CHEBI:136567"}],"evidences":[{"evidenceCode":"ECO:0000250","source":"UniProtKB","id":"P49888"}]},"physiologicalReactions":[{"directionType":"left-to-right","reactionCrossReference":{"database":"Rhea","id":"RHEA:52349"},"evidences":